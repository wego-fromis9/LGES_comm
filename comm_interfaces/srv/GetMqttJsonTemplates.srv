# Empty message_type returns all comm_manager MQTT JSON templates.
# Otherwise return one template by message type, e.g. state, factsheet, connection.
string message_type
---
bool success
string message

# JSON object:
# {
#   "baseTopic": "uagv/v2/WEGO/AMR-001",
#   "templates": [
#     {
#       "messageType": "state",
#       "direction": "outbound",
#       "sourceOwner": "comm_manager.backend_publisher",
#       "topicSuffix": "state",
#       "qos": 0,
#       "retain": true,
#       "payloadTemplate": {},
#       "headerFields": ["headerId", "timestamp", "version", "manufacturer", "serialNumber"],
#       "fields": {},
#       "routing": {}
#     }
#   ]
# }
string templates_json
